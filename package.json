{
    "name": "fer-07-project",
    "version": "1.0.0",
    "description": "",
    "main": "index.html",
    "type": "module",
    "scripts": {
        "init-project": "npm install && npm-run-all init:*",
        "init:dirs": "mkdirp dist src/sass src/css src/vendor src/images src/js",
        "init:files": "touch README.md src/index.html src/sass/style.scss src/js/script.js",
        "test": "npm-run-all test:*",
        "test:html": "html-validate src/*.html",
        "test:js": "eslint --fix src/js/",
        "test:scss": "stylelint --fix src/sass/",
        "prebuild": "node scripts/prebuild.js",
        "build": "npm-run-all build:* test",
        "build:clean": "rimraf dist && mkdirp dist",
        "build:copy": "copyfiles -a -u 1 -e \"**/sass/**/*\" -e \"**/.gitkeep\" \"src/**/*\" dist && copyfiles src/supabase.js dist",
        "build:sass": "sass --style=compressed --no-source-map src/sass:dist/css",
        "build:autoprefixer": "postcss dist/css/*.css --use autoprefixer -d dist/css",
        "build-dev": "npm-run-all build-dev:sass build:autoprefixer",
        "build-dev:sass": "sass --style=expanded --source-map src/sass:dist/css",
        "watch": "npm-run-all build-dev -p watch:* watch:browsersync",
        "watch:browsersync": "browser-sync start --server dist --files \"dist/**/*\" --ignore \"dist/db/**/*\" --browser \"chrome\"",
        "watch:sassprefixer": "onchange \"src/sass/**/*.scss\" -- npm run build-dev",
        "watch:copy": "onchange -e \"**/sass/**/*\" -e \"**/.gitkeep\" \"src/**/*\" -- copyfiles -a -u 1 {{changed}} dist"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "autoprefixer": "^10.2.4",
        "browser-sync": "^2.26.3",
        "copyfiles": "^2.1.0",
        "dotenv": "^17.3.1",
        "eslint": "^8.56.0",
        "globstar": "^1.0.0",
        "html-validate": "^7.3.2",
        "live-server": "^1.2.2",
        "mkdirp": "^0.5.1",
        "npm-run-all": "^4.1.5",
        "onchange": "^7.1.0",
        "postcss": "^8.2.6",
        "postcss-cli": "^8.3.1",
        "postcss-scss": "^4.0.4",
        "rimraf": "^3.0.2",
        "sass": "^1.44.0",
        "stylelint": "^14.11.0",
        "stylelint-config-standard-scss": "^5.0.0",
        "stylelint-scss": "^4.3.0"
    },
    "dependencies": {
        "@supabase/supabase-js": "^2.98.0",
        "flickity": "^3.0.0"
    }
}
